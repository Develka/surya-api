# surya-api environment variables (example)
#
# Copy to .env and adjust as needed. All values below are the defaults the code
# falls back to, so every line is optional unless noted otherwise.
#
# Two groups:
#   1) surya-api specific  - read directly by this project's code.
#   2) Surya / vLLM settings - read by surya.settings (pydantic BaseSettings)
#      from the process environment.

# ---------------------------------------------------------------------------
# 1) surya-api specific
# ---------------------------------------------------------------------------

# Docker cache storage mode for the vLLM container:
#   volume - Docker named volumes (default; fast + cross-platform, avoids the
#            slow WSL2 9P path on Windows/macOS)
#   bind   - host directory bind mounts (uses DOCKER_HF_CACHE_PATH and
#            DOCKER_VLLM_CACHE_PATH below)
SURYA_DOCKER_CACHE_MODE=volume

# Named volumes used when SURYA_DOCKER_CACHE_MODE=volume.
SURYA_HF_CACHE_VOLUME=surya-hf-cache
SURYA_VLLM_CACHE_VOLUME=surya-vllm-cache

# Host path for the vLLM torch.compile cache when SURYA_DOCKER_CACHE_MODE=bind.
# (The HuggingFace cache host path in bind mode is DOCKER_HF_CACHE_PATH below.)
DOCKER_VLLM_CACHE_PATH=~/.cache/surya-vllm

# Default input file for the pytest integration test (ocr_page.py).
# Can also be passed with: pytest ocr_page.py --file <path>
# OCR_TEST_FILE=

# ---------------------------------------------------------------------------
# 2) Surya / vLLM inference settings (surya.settings)
# ---------------------------------------------------------------------------

# Model + backend
SURYA_MODEL_CHECKPOINT=datalab-to/surya-ocr-2
SURYA_INFERENCE_BACKEND=vllm

# Attach to an already-running OpenAI-compatible server instead of spawning a
# container (leave empty to let surya-api manage the vLLM container).
# SURYA_INFERENCE_URL=

# Concurrent inference workers and startup budget (seconds).
SURYA_INFERENCE_PARALLEL=8
SURYA_INFERENCE_STARTUP_TIMEOUT=600

# Fixed host port for the inference server (leave empty to auto-pick a free one).
# SURYA_INFERENCE_PORT=

# HuggingFace cache host path (used in bind mode, and as the default model cache).
DOCKER_HF_CACHE_PATH=~/.cache/huggingface

# vLLM container configuration
VLLM_DOCKER_IMAGE=vllm/vllm-openai:v0.20.1
VLLM_API_KEY=EMPTY
VLLM_GPUS=0
VLLM_GPU_TYPE=4090
VLLM_DTYPE=bfloat16
VLLM_MAX_MODEL_LEN=18000
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_ENABLE_MTP=true
VLLM_MTP_TOKENS=2
# Extra space-separated args appended to the vLLM server command.
# VLLM_EXTRA_ARGS=
